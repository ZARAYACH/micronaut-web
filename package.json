{
  "name": "micronaut-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:snippet-css": "node scripts/generate-docs-snippet-css.mjs",
    "protocol": "npm run generate:snippet-css && npm run test:platform-docs && npm run test:guides && npm run test:main-site && node scripts/validate-protocol.mjs && node scripts/validate-docs-snippet-style-sharing.mjs",
    "snippet-styles": "npm run generate:snippet-css && node scripts/validate-docs-snippet-style-sharing.mjs",
    "sync:platform-projects": "node scripts/sync-platform-docs-fixture.mjs",
    "sync:main-site-content": "node scripts/sync-main-site-content.mjs && npm run normalize:main-site-markdown",
    "normalize:main-site-markdown": "node scripts/normalize-main-site-markdown.mjs",
    "extract:main-site-resources": "node scripts/extract-main-site-resources.mjs",
    "render:platform-docs": "node scripts/render-platform-docs.mjs",
    "render:guides": "node scripts/render-guides.mjs",
    "prepare:generated-docs": "npm run render:platform-docs",
    "prepare:generated-content": "node scripts/prepare-generated-content.mjs",
    "test:main-site": "node --test scripts/main-site-blog-redirects.test.mjs",
    "test:platform-docs": "node --test scripts/platform-docs/*.test.mjs",
    "test:guides": "node --test scripts/guides/*.test.mjs",
    "dev": "npm run protocol && npm run prepare:generated-content && astro dev --host 127.0.0.1",
    "build": "npm run protocol && npm run prepare:generated-content && astro build && node scripts/prepare-template-artifacts.mjs",
    "preview": "astro preview --host 127.0.0.1"
  },
  "dependencies": {
    "@astrojs/react": "latest",
    "asciidoctor": "^3.0.4",
    "astro": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "latest",
    "cmdk": "^1.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "parse5": "^7.3.0",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "shiki": "^4.1.0",
    "smol-toml": "^1.6.1",
    "tailwind-merge": "latest",
    "tailwindcss": "latest"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "typescript": "latest"
  },
  "overrides": {
    "vite": "^7.0.0"
  }
}
